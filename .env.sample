# API Keys for AI Services
ANTHROPIC_API_KEY=
ENGINEER_NAME=Dan
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
FIRECRAWL_API_KEY=

# E2B - Cloud sandbox environments for AI agents (https://e2b.dev)
# Required for Agent Sandbox Skill integration
E2B_API_KEY=

# Hook behavior (optional)
# Set to 1 to cache model extraction results per session (reduces transcript reads)
CLAUDE_HOOKS_ENABLE_CACHING=

# Multi-Agent Teams (optional)
# Enable via: export CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1 (set in shell, not this file)
# The observability system automatically detects and tracks:
#   - team_create, team_delete → Team lifecycle
#   - task_create, task_update, task_list, task_get → Task management
#   - send_message → Inter-agent communication
# All agent team tool events are auto-tagged with _agent_team_tool=true for server filtering

# Orchestration local-process policy (optional overrides)
# Set to 0 to require agents to specify an explicit cwd (default: 1 = allow unspecified)
ORCH_LP_ALLOW_UNSPECIFIED_CWD=1

# Orchestration admin gate (optional)
# When unset or empty: open mode — sensitive mutations and admin reads do not require a client token (local dev default).
# When set: protected mode — send x-orchestration-admin-token or Authorization: Bearer <value> on gated routes.
# Read routes using the token: GET /api/orchestration/admin-audit, GET /api/orchestration/admin/retention-config
# (see docs/technical-design-multi-agent-orchestration.md §6)
ORCH_ADMIN_TOKEN=

# Orchestration retention (optional — set to prune old data at startup and via POST .../admin/prune-history)
# Introspection only (no prune): GET /api/orchestration/admin/retention-config — effective limits + limit_source JSON.
# Admin audit log: age-based (days) and/or row-cap pruning
ORCH_ADMIN_AUDIT_MAX_DAYS=
ORCH_ADMIN_AUDIT_MAX_ROWS=

# Live task runs (orchestration_task_runs — one row per task)
ORCH_TASK_RUNS_MAX_DAYS=
ORCH_TASK_RUNS_MAX_ROWS=

# Archived task run history (orchestration_task_run_history — terminal runs only)
# Per-field fallback: if ORCH_TASK_RUN_HISTORY_MAX_DAYS or _MAX_ROWS is unset, that dimension uses the matching ORCH_TASK_RUNS_* value.
ORCH_TASK_RUN_HISTORY_MAX_DAYS=
ORCH_TASK_RUN_HISTORY_MAX_ROWS=

# Orchestration retry policy (optional)
ORCH_TASK_MAX_ATTEMPTS=1
ORCH_TASK_RETRY_BACKOFF_MS=1000