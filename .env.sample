# API Keys for AI Services
ANTHROPIC_API_KEY=
ENGINEER_NAME=Dan
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
FIRECRAWL_API_KEY=

# E2B - Cloud sandbox environments for AI agents (https://e2b.dev)
# Required for Agent Sandbox Skill integration
E2B_API_KEY=

# Hook behavior (optional)
# Set to 1 to cache model extraction results per session (reduces transcript reads)
CLAUDE_HOOKS_ENABLE_CACHING=

# Orchestration local-process policy (optional overrides)
# Set to 0 to require agents to specify an explicit cwd (default: 1 = allow unspecified)
ORCH_LP_ALLOW_UNSPECIFIED_CWD=1